{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Odenknight/gkos-standard/schemas/diagnostics-sidecar.schema.json",
  "title": "Diagnostics sidecar (L4)",
  "description": "Per-note deterministic diagnostics export. Sidecar location: .okf/diagnostics/<uid>.diagnostics.yaml.",
  "type": "object",
  "required": ["target_uid", "source_path", "content_hash", "engine_version", "generated_at", "diagnostics"],
  "properties": {
    "target_uid": { "oneOf": [{ "$ref": "okf-common.defs.json#/$defs/uid" }, { "type": "null" }] },
    "source_path": { "type": "string" },
    "content_hash": { "$ref": "okf-common.defs.json#/$defs/contentHash" },
    "engine_version": { "type": "string" },
    "policy_hash": { "type": "string" },
    "generated_at": { "$ref": "okf-common.defs.json#/$defs/timestamp" },
    "diagnostics": { "type": "array", "items": { "$ref": "okf-common.defs.json#/$defs/diagnostic" } }
  },
  "additionalProperties": false
}
